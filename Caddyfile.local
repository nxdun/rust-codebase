{
    debug
    admin :2026
    email admin@nadzu.me
    auto_https disable_redirects
}

http://:8080 {
    handle {
        reverse_proxy app:8080
    }
}

nadzu.localhost {
    tls internal

    handle_path /downloads/* {
        root * /var/www/downloads
        file_server browse
    }

    # Proxy everything else to the Rust backend
    handle {
        reverse_proxy app:8080
    }
}
