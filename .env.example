APP_NAME = "nadzu-be"
APP_HOST = "127.0.0.1"
APP_PORT = "8080"
APP_ENV = "development"
RUST_LOG = "nadzu=debug,tower_http=info"

# DATABASE_HOST = "127.0.0.1"
# DATABASE_PORT = "5432"
# DATABASE_USER = "postgres"
# DATABASE_PASS =
# DATABASE_NAME = "cutedb"
# REDIS_URL = "redis://127.0.0.1:6379"

# CORS policy:
#   "none" or "" -> disables CORS entirely
#   "*"           -> allows all origins (dev only)
#   "https://domain.tld,https://sub.domain.tld" -> comma-separated allowed origins

ALLOWED_ORIGINS = "*"

### -------------------------
### yt-dlp settings
### -------------------------
DOWNLOAD_DIR = "./downloads"
YTDLP_PATH = "yt-dlp"
# YTDLP_COOKIES_FILE = "./cookies.txt"
YTDLP_OUTPUT_TEMPLATE = "%(title)s.%(ext)s"

MAX_CONCURRENT_DOWNLOADS = "2"

### -------------------------
### notes
### -------------------------

# Docker image defaults are set in Dockerfile:
# - APP_HOST=0.0.0.0
# - APP_ENV=development
# - DOWNLOAD_DIR=/home/app/downloads
# - YTDLP_PATH=/opt/yt/bin/yt-dlp

# Optional: explicit extractor args (overrides POT URL auto-generation)
# YTDLP_EXTRACTOR_ARGS = "youtube:po_token_provider=bgutil:http://127.0.0.1:4416"
# Optional: used to auto-build extractor args when YTDLP_EXTRACTOR_ARGS is not set
# YTDLP_POT_PROVIDER_URL = "http://127.0.0.1:4416"

# Google reCAPTCHA secret key (required for /api/v1/captcha/verify)
# CAPTCHA_SECRET_KEY = "your_recaptcha_secret"